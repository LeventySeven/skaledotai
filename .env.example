# Database (Supabase Postgres pooler URL)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=

# Tavily (web search)
TAVILY_API_KEY=

# AgentQL
AGENTQL_API_KEY=

# X / Twitter API
X_API_BEARER_TOKEN=
X_ENABLE_FULL_ARCHIVE=false
X_REDIRECT_URI=http://localhost:3000/api/auth/x/callback
X_SCOPES=tweet.read users.read follows.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=
